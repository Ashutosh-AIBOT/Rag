# ==========================
# APP
# ==========================
APP_NAME=Advanced RAG Platform
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# ==========================
# API KEYS
# ==========================
GOOGLE_API_KEY=
GROQ_API_KEY=
NVIDIA_API_KEY=
COHERE_API_KEY=

# ==========================
# DATABASE
# ==========================
SQLITE_DB_PATH=data/rag.db
CHROMA_DB_PATH=data/chroma

# ==========================
# EMBEDDINGS
# ==========================
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ==========================
# RERANKER
# ==========================
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ==========================
# DEFAULT LLM
# ==========================
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_LLM_MODEL=gemini-2.5-flash

# ==========================
# QUERY
# ==========================
TOP_K=20
FINAL_TOP_K=5

# ==========================
# CHUNKING
# ==========================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ==========================
# CONCURRENCY
# ==========================
LLM_MAX_CONCURRENT_REQUESTS=3

# ==========================
# FILE UPLOAD
# ==========================
MAX_UPLOAD_SIZE_MB=50